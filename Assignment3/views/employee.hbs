<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Details</title>
    <style>
        body {
            background-color: #282a36;
            color: #f8f8f2;
            font-family: Georgia, serif;
            padding: 30px;
        }
        a {
            color: #f8f8f2;
            text-decoration: underline;
        }
        a:hover {
            color: #bd93f9;
        }
        table {
            border-collapse: collapse;
            margin-top: 15px;
        }
        th, td {
            text-align: left;
            padding: 4px 15px 4px 0;
        }
        .highlight-yellow {
            background-color: rgba(241, 250, 140, 0.4); /* Muted yellow to match dark theme readability */
            color: #f8f8f2; 
        }
        .header-section {
            margin-bottom: 30px;
        }
        .header-section p {
            margin: 5px 0;
        }
    </style>
</head>
<body>
    <h1>Employee Details</h1>
    
    <div class="header-section">
        <p>Name: {{employee.name}}</p>
        <p>Phone: {{employee.phone}}</p>
        <a href="/employee/{{employee.employeeId}}/edit">Edit Details</a>
    </div>

    <h2>Shifts</h2>
    
    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Start Time</th>
                <th>End Time</th>
            </tr>
        </thead>
        <tbody>
            {{#each shifts}}
                <tr>
                    <td>{{this.date}}</td>
                    <td class="{{#if this.isMorningStart}}highlight-yellow{{/if}}">{{this.startTime}}</td>
                    <td class="{{#if this.isMorningEnd}}highlight-yellow{{/if}}">{{this.endTime}}</td>
                </tr>
            {{/each}}
        </tbody>
    </table>

</body>
</html>
