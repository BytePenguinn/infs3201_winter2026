<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of Employees</title>
    <style>
        body {
            background-color: #282a36;
            color: #f8f8f2;
            font-family: Georgia, serif;  
            padding: 30px;
        }
        a {
            color: #bd93f9;
        }
        a:hover {
            color: #ff79c6;
        }
        ul {
            font-size: 1.2rem;
        }
    </style>
</head>
<body>
    <h1>List of Employees</h1>
    
    <ul>
        {{#each employees}}
            <li>
                <a href="/employee/{{this.employeeId}}">{{this.name}}</a>
            </li>
        {{/each}}
    </ul>

</body>
</html>
